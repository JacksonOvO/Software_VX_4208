build VX4204.pbd : link VX4204_part0.pbi VX4204_part1.pbi VX4204_part2.pbi VX4204_part3.pbi VX4204_part4.pbi VX4204_part5.pbi VX4204_part6.pbi VX4204_part7.pbi
build VX4204.pbw : browsedata VX4204.pbd


