build VX4204_part0.pbi : link common.pbi diagnose.pbi warn.pbi watchdog.pbi MbCommunication.pbi IoInit.pbi HModbusOptimize.pbi
build VX4204_part1.pbi : link Iocontrol.pbi MasterCommunication.pbi main.pbi system_stm32f30x.pbi stm32f30x_adc.pbi stm32f30x_can.pbi stm32f30x_comp.pbi
build VX4204_part2.pbi : link stm32f30x_crc.pbi stm32f30x_dac.pbi stm32f30x_dbgmcu.pbi stm32f30x_dma.pbi stm32f30x_exti.pbi stm32f30x_flash.pbi stm32f30x_gpio.pbi
build VX4204_part3.pbi : link stm32f30x_i2c.pbi stm32f30x_iwdg.pbi stm32f30x_misc.pbi stm32f30x_opamp.pbi stm32f30x_pwr.pbi stm32f30x_rcc.pbi stm32f30x_rtc.pbi
